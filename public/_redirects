# Cloudflare Pages does NOT support query-string matching in _redirects sources.
# Placeholders like :id are NOT expanded inside query strings — use :splat instead.

# News page-1 alias → main listing
/news/page-1 /news 301
/news/page-1.html /news 301

# Legacy static product URLs → purchase SPA
# /goods/ab_xxx  and  /goods/ab_xxx.html  →  /goods?id=ab_xxx
/goods/* /goods?id=:splat 301
