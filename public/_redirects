# Cloudflare Pages does NOT support query-string matching in _redirects.
# Previous rules like:
#   /news.html?page=2  /news/page-2.html  301
# were parsed as "/news.html → /news/page-2.html", so clicking page "1"
# (href=/news.html) always bounced back to page 2.

# Normalize page-1 SSG alias to the main news listing (/news ← news.html)
/news/page-1 /news 301
/news/page-1.html /news 301
